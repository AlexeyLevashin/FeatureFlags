# Скомпилированные бинарники (результат go build)
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# Бинарники тестов (результат go test -c)
*.test

# Отчеты покрытия кода тестами
*.out
coverage.txt

# Папка с вендорными зависимостями (при использовании go.mod она обычно не пушится)
vendor/

# Файлы конфигурации окружения (САМОЕ ВАЖНОЕ - никогда не пушь пароли от БД)
.env
*.local

# Логи
*.log

# Файлы GoLand (настройки IDE, которые у каждого разработчика свои)
.idea/
*.iml

# Системные файлы macOS (если кто-то будет кодить с мака)
.DS_Store